---
/**
 * An inline EIP link inside decision text. Renders as a real navigable anchor
 * (better for crawlers than the SPA's dotted span) and carries `data-eip-preview`
 * so the shared `EipPreviewLayer` can show the hover card. Mirrors the anchor in
 * `KeyDecisionsSection.EipLinkWithTooltip`.
 */
interface Props {
  id: number;
}
const { id } = Astro.props;
---

<a
  href={`/eips/${id}`}
  class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-200"
  style="border-bottom: 1px dotted currentColor"
  data-eip-preview={String(id)}>EIP-{id}</a>
