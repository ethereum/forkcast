---
import type { ClientSupportMatrix } from '../../types';
import SupportCell from './SupportCell.astro';

/** Static port of `DevnetSpecPage`'s `ClientMatrix`. */
interface Props {
  title: string;
  data: ClientSupportMatrix;
}
const { title, data } = Astro.props;
---

{
  data.clients.length > 0 && (
    <section class="mt-8">
      <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-4">{title}</h2>
      <div class="overflow-x-auto -mx-4 px-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-700">
              <th class="text-left py-2 pr-4 font-medium text-slate-600 dark:text-slate-400">EIP</th>
              {data.clients.map((client) => (
                <th class="py-2 px-2 font-medium text-slate-600 dark:text-slate-400 text-center">{client}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {data.matrix.map((row) => (
              <tr class="border-b border-slate-100 dark:border-slate-800">
                <td class="py-2 pr-4 text-slate-700 dark:text-slate-300 whitespace-nowrap">{row.label}</td>
                {data.clients.map((client) => (
                  <td class="py-2 px-2 text-center">
                    <SupportCell status={row.support[client] || 'unknown'} />
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )
}
