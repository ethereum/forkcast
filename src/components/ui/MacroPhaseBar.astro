---
import { MACRO_PHASES } from '../../constants/timeline-phases';
import type { MacroPhase } from '../../types/timeline';
import Tooltip from './Tooltip.astro';

/** Static counterpart of the React `MacroPhaseBar`. */
interface Props {
  currentPhase: MacroPhase;
  shipped?: boolean;
}

const { currentPhase, shipped } = Astro.props;

const PHASE_ORDER: MacroPhase[] = ['headliners', 'scoping', 'devnets', 'testnets', 'mainnet'];
const currentIndex = PHASE_ORDER.indexOf(currentPhase);
const currentLabel = shipped ? 'Live' : MACRO_PHASES[currentIndex]?.label;

const segmentClasses = (index: number): string => {
  if (shipped) return 'bg-emerald-500 dark:bg-emerald-400';
  if (index < currentIndex) return 'bg-emerald-500 dark:bg-emerald-400';
  if (index === currentIndex) return 'bg-purple-500 dark:bg-purple-400';
  return 'bg-slate-200 dark:bg-slate-700';
};

const labelAlign = (index: number): string =>
  index === 0 ? 'left-0' : index === PHASE_ORDER.length - 1 ? 'right-0' : 'left-1/2 -translate-x-1/2';
---

<div>
  <div class="flex gap-1 pb-2.5">
    {
      MACRO_PHASES.map((phase, index) => (
        <div class="flex-1 relative">
          <Tooltip text={phase.label} position="top" class="w-full">
            <div class={`w-full h-2 rounded-full ${segmentClasses(index)} transition-colors`} />
          </Tooltip>
          {((shipped && index === PHASE_ORDER.length - 1) || (!shipped && index === currentIndex)) && (
            <p
              class={`absolute mt-0.5 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap ${labelAlign(index)}`}
            >
              {currentLabel}
            </p>
          )}
        </div>
      ))
    }
  </div>
</div>
