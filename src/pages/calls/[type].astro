---
import Layout from '../../layouts/Layout.astro';
import CallsIndexPage from '../../components/CallsIndexPage';
import { protocolCalls, callTypeNames, type CallType } from '../../data/calls';
import { upcomingCalls } from '../../domain/calls/upcomingCalls';

// Concrete call-type scopes, e.g. /calls/acde, /calls/bal. Aggregate filters
// (acd, breakouts) stay query-string state on /calls and are not routes (Phase 1).
export function getStaticPaths() {
  const types = new Set<string>();
  for (const call of protocolCalls) types.add(call.type);
  for (const call of upcomingCalls) types.add(call.type);

  return [...types].map((type) => {
    const name = callTypeNames[type as CallType] || type.toUpperCase();
    return {
      params: { type },
      props: {
        title: `${name} Calls - Forkcast`,
        description: `Browse ${name} protocol calls tracked on Forkcast.`,
      },
    };
  });
}

const type = Astro.params.type!;
const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <CallsIndexPage client:only="react" scope={type} />
</Layout>
