---
import Layout from '../../layouts/Layout.astro';
import {
  getAllDevnetSpecIds,
  getDevnetSpec,
  getDevnetSeriesSiblings,
} from '../../data/devnet-specs';
import { getActiveDevnetNetworkKeys, getNetworkEntry, getNetworkMetadata } from '../../domain/devnets/networks';
import { inlineMarkdownToHtml } from '../../utils/markdownHtml';
import DevnetStatusBadge from '../../components/devnets/DevnetStatusBadge.astro';
import ClientMatrix from '../../components/devnets/ClientMatrix.astro';
import ResourceLinks from '../../components/devnets/ResourceLinks.astro';

// Local spec IDs plus active network IDs from the build-time networks snapshot.
// Active keys without a local spec render network-only pages.
export function getStaticPaths() {
  const ids = Array.from(new Set([...getAllDevnetSpecIds(), ...getActiveDevnetNetworkKeys()]));
  return ids.map((id) => {
    const spec = getDevnetSpec(id);
    return {
      params: { id },
      props: {
        title: spec ? `${spec.title} - Forkcast` : `${id} - Forkcast`,
        description: spec
          ? `Devnet spec for ${id}: EIP list, client implementation status, and spec references.`
          : `Devnet network details for ${id}.`,
      },
    };
  });
}

const id = Astro.params.id!;
const { title, description } = Astro.props;

const spec = getDevnetSpec(id);
const networkEntry = getNetworkEntry(id);
const categoryKey = id.replace(/-devnet-\d+$/, '');
const metadata = getNetworkMetadata(categoryKey);
const { prev, next } = getDevnetSeriesSiblings(id);

const dateOpts = { year: 'numeric', month: 'short', day: 'numeric' } as const;
const navLinkClass =
  'px-2 py-1 rounded text-slate-500 hover:text-slate-700 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-slate-800 transition-colors';
const navDisabledClass = 'px-2 py-1 text-slate-300 dark:text-slate-600';
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 p-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-6 flex items-center justify-between gap-3">
        <a
          href="/devnets"
          class="text-sm text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors"
          >&larr; Back to Devnets</a
        >
        <div class="flex items-center gap-3">
          {
            (prev || next) && (
              <nav class="flex items-center gap-1 text-sm">
                {prev ? (
                  <a href={`/devnets/${prev}`} class={navLinkClass} title={prev}>
                    &larr; Prev
                  </a>
                ) : (
                  <span class={navDisabledClass}>&larr; Prev</span>
                )}
                <span class="text-slate-300 dark:text-slate-600">|</span>
                {next ? (
                  <a href={`/devnets/${next}`} class={navLinkClass} title={next}>
                    Next &rarr;
                  </a>
                ) : (
                  <span class={navDisabledClass}>Next &rarr;</span>
                )}
              </nav>
            )
          }
        </div>
      </div>

      {
        spec ? (
          <Fragment>
            <div class="mb-8">
              <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">{spec.title}</h1>
              <div class="mt-2 flex items-center gap-3 text-sm text-slate-500 dark:text-slate-400">
                {networkEntry && (
                  <Fragment>
                    <a
                      href={`https://ethpandaops.io/networks/${spec.id}/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors underline decoration-1 underline-offset-2"
                    >
                      ethPandaOps Dashboard
                    </a>
                    <span>&middot;</span>
                  </Fragment>
                )}
                <a
                  href={spec.sourceUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors underline decoration-1 underline-offset-2"
                >
                  View Specification
                </a>
                <span>&middot;</span>
                {spec.genesisTime && (
                  <Fragment>
                    <span>Launched {new Date(spec.genesisTime * 1000).toLocaleDateString('en-US', dateOpts)}</span>
                    <span>&middot;</span>
                  </Fragment>
                )}
                <span>Scraped {new Date(spec.scrapedAt).toLocaleDateString('en-US', dateOpts)}</span>
              </div>
            </div>

            {spec.sameSpecAs && (
              <div class="mb-8 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 px-4 py-3 text-sm text-slate-600 dark:text-slate-400">
                This devnet used the same spec as{' '}
                <a
                  href={`/devnets/${spec.sameSpecAs}`}
                  class="text-purple-600 hover:text-purple-800 dark:text-purple-400 dark:hover:text-purple-300 font-medium transition-colors"
                >
                  {spec.sameSpecAs}
                </a>
                .
              </div>
            )}

            {spec.announcements.length > 0 && (
              <section class="mb-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-sm text-blue-900 dark:text-blue-200 overflow-hidden divide-y divide-blue-200 dark:divide-blue-800">
                {spec.announcements.map((text) => (
                  <div class="flex gap-3 px-4 py-3">
                    <svg
                      class="w-4 h-4 shrink-0 mt-0.5 text-blue-400 dark:text-blue-500"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    <span set:html={inlineMarkdownToHtml(text, { bold: true })} />
                  </div>
                ))}
              </section>
            )}

            {(spec.specReferences.consensusSpecs || spec.specReferences.executionSpecs) && (
              <div class="mb-8 flex flex-wrap gap-3">
                {spec.specReferences.consensusSpecs && (
                  <a
                    href={spec.specReferences.consensusSpecs.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors"
                  >
                    Consensus Specs
                    <span class="px-1.5 py-0.5 rounded bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 text-xs font-mono">
                      {spec.specReferences.consensusSpecs.version}
                    </span>
                  </a>
                )}
                {spec.specReferences.executionSpecs && (
                  <a
                    href={spec.specReferences.executionSpecs.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors"
                  >
                    Execution Specs
                    <span class="px-1.5 py-0.5 rounded bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 text-xs font-mono">
                      {spec.specReferences.executionSpecs.version}
                    </span>
                  </a>
                )}
              </div>
            )}

            <ResourceLinks networkEntry={networkEntry} metadataLinks={metadata?.links ?? null} />

            {spec.eips.length > 0 && (
              <section class="mt-8">
                <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-4">EIP List</h2>
                <div class="overflow-x-auto -mx-4 px-4">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-slate-200 dark:border-slate-700">
                        <th class="text-left py-2 pr-4 font-medium text-slate-600 dark:text-slate-400">EIP</th>
                        <th class="text-left py-2 pr-4 font-medium text-slate-600 dark:text-slate-400">Title</th>
                        <th class="text-left py-2 font-medium text-slate-600 dark:text-slate-400">Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      {spec.eips.map((eip) => (
                        <tr class="border-b border-slate-100 dark:border-slate-800">
                          <td class="py-2 pr-4">
                            <a
                              href={`/eips/${eip.number}`}
                              class="text-purple-600 hover:text-purple-800 dark:text-purple-400 dark:hover:text-purple-300 font-medium transition-colors"
                            >
                              EIP-{eip.number}
                            </a>
                          </td>
                          <td class="py-2 pr-4 text-slate-700 dark:text-slate-300">{eip.title}</td>
                          <td class="py-2">
                            <DevnetStatusBadge status={eip.status} />
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            )}

            <ClientMatrix title="Execution Layer Client Support" data={spec.elClientSupport} />
            <ClientMatrix title="Consensus Layer Client Support" data={spec.clClientSupport} />
          </Fragment>
        ) : (
          <Fragment>
            <div class="mb-8">
              <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">{id}</h1>
              <div class="mt-2 flex items-center gap-3 text-sm text-slate-500 dark:text-slate-400">
                {networkEntry && (
                  <a
                    href={`https://ethpandaops.io/networks/${id}/`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors underline decoration-1 underline-offset-2"
                  >
                    ethPandaOps Dashboard
                  </a>
                )}
              </div>
              {metadata?.description && (
                <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">{metadata.description}</p>
              )}
            </div>

            <ResourceLinks networkEntry={networkEntry} metadataLinks={metadata?.links ?? null} />
          </Fragment>
        )
      }
    </div>
  </div>
</Layout>

<script define:vars={{ prev, next }}>
  // Arrow-key navigation between sibling devnets (replaces the React useNavigate/useEffect).
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowLeft' && prev) window.location.assign(`/devnets/${prev}`);
    if (e.key === 'ArrowRight' && next) window.location.assign(`/devnets/${next}`);
  });
</script>
