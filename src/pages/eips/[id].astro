---
import Layout from '../../layouts/Layout.astro';
import { EipPage } from '../../components/eip';
import { eipsData } from '../../data/eips';
import { getLaymanTitle, getProposalPrefix } from '../../utils/eip';

export function getStaticPaths() {
  return eipsData
    .map((eip) => {
      const label = `${getProposalPrefix(eip)}-${eip.id}`;
      return {
        params: { id: String(eip.id) },
        props: {
          title: `${label}: ${getLaymanTitle(eip)} - Forkcast`,
          description: `Description, timeline, and status of ${label}: ${getLaymanTitle(eip)}`,
        },
      };
    });
}

const id = Astro.params.id!;
const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <EipPage client:only="react" id={id} />
</Layout>
