---
import Layout from '../layouts/Layout.astro';
import UpgradeCard from '../components/ui/UpgradeCard.astro';
import KeyDecisionText from '../components/decisions/KeyDecisionText.astro';
import EipPreviewLayer from '../components/decisions/EipPreviewLayer.astro';
import { staticPageMetadata } from '../domain/routes/pageMetadata';
import { networkUpgrades, type NetworkUpgrade } from '../data/upgrades';
import { getRecentCalls, isOneOffCall, callTypeNames, type CallType } from '../data/calls';
import { eipsData, eipById } from '../data/eips';
import { getProposalPrefix, getLaymanTitle, getInclusionStage } from '../utils/eip';
import { loadLatestAcdMeeting } from '../domain/decisions/keyDecisions';
import { collectEipPreviews } from '../domain/decisions/decisionText';
import type { EIP } from '../types/eip';

const latestDatedStatusTimestamp = (eip: EIP): number | null => {
  let latest: number | null = null;
  for (const fork of eip.forkRelationships) {
    for (const entry of fork.statusHistory) {
      if (!entry.date) continue;
      const timestamp = Date.parse(entry.date);
      if (!Number.isFinite(timestamp)) continue;
      latest = latest === null ? timestamp : Math.max(latest, timestamp);
    }
  }
  return latest;
};

const quickLinks: NetworkUpgrade[] = (() => {
  const active = networkUpgrades.filter((u) => !u.disabled);
  const previous = [...active].reverse().find((u) => u.status === 'Live');
  const current = active.find((u) => u.status === 'Upcoming');
  const future = active.find((u) => u.status === 'Planning' || u.status === 'Research');
  return [previous, current, future].filter((u): u is NetworkUpgrade => u !== undefined);
})();

const featuredEips: EIP[] = eipsData
  .map((eip) => ({ eip, lastUpdate: latestDatedStatusTimestamp(eip) }))
  .filter((item): item is { eip: EIP; lastUpdate: number } => item.lastUpdate !== null)
  .sort((a, b) => b.lastUpdate - a.lastUpdate)
  .slice(0, 4)
  .map((item) => item.eip);

const recentCalls = getRecentCalls(5);
const recentMeetingDecisions = loadLatestAcdMeeting();
const decisionEipPreviews = recentMeetingDecisions
  ? collectEipPreviews(recentMeetingDecisions.decisions, eipById)
  : [];

const getForkDisplayName = (forkName: string): string =>
  ({ Hegota: 'Hegotá' })[forkName] || forkName;

const getForkColor = (forkName: string): string => {
  const upgrade = networkUpgrades.find(
    (u) => u.name.includes(forkName) || u.id === forkName.toLowerCase(),
  );
  if (!upgrade) {
    return 'bg-slate-50/50 text-slate-600 dark:bg-slate-900/30 dark:text-slate-400 border border-slate-200 dark:border-slate-700';
  }
  switch (upgrade.status) {
    case 'Live':
      return 'bg-emerald-50/50 text-emerald-600 dark:bg-emerald-950/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800';
    case 'Upcoming':
      return 'bg-blue-50/50 text-blue-600 dark:bg-blue-950/30 dark:text-blue-400 border border-blue-200 dark:border-blue-800';
    case 'Planning':
      return 'bg-purple-50/50 text-purple-600 dark:bg-purple-950/30 dark:text-purple-400 border border-purple-200 dark:border-purple-800';
    default:
      return 'bg-slate-50/50 text-slate-600 dark:bg-slate-900/30 dark:text-slate-400 border border-slate-200 dark:border-slate-700';
  }
};

const getStageLabel = (stage: string): string => {
  switch (stage) {
    case 'Considered for Inclusion':
      return 'Considered';
    case 'Proposed for Inclusion':
      return 'Proposed';
    case 'Scheduled for Inclusion':
      return 'Scheduled';
    case 'Declined for Inclusion':
      return 'Declined';
    case 'Included':
      return 'Included';
    case 'Withdrawn':
      return 'Withdrawn';
    default:
      return stage;
  }
};

const callTypeBadgeColors: Record<CallType, string> = {
  acdc: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300',
  acde: 'bg-sky-100 dark:bg-sky-900/30 text-sky-700 dark:text-sky-300',
  acdt: 'bg-cyan-100 dark:bg-cyan-900/30 text-cyan-700 dark:text-cyan-300',
  epbs: 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300',
  bal: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300',
  focil: 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300',
  price: 'bg-rose-100 dark:bg-rose-900/30 text-rose-700 dark:text-rose-300',
  tli: 'bg-pink-100 dark:bg-pink-900/30 text-pink-700 dark:text-pink-300',
  pqts: 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300',
  rpc: 'bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300',
  zkevm: 'bg-fuchsia-100 dark:bg-fuchsia-900/30 text-fuchsia-700 dark:text-fuchsia-300',
  etm: 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300',
  awd: 'bg-lime-100 dark:bg-lime-900/30 text-lime-700 dark:text-lime-300',
  pqi: 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300',
  fcr: 'bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300',
  aa: 'bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300',
  p2p: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300',
};
const fallbackBadgeColor = 'bg-slate-100 dark:bg-slate-700/50 text-slate-600 dark:text-slate-300';
const arrowPath = 'M9 5l7 7-7 7';
---

<Layout {...staticPageMetadata.home}>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 p-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10 text-center">
        <h1 class="text-2xl sm:text-3xl font-light text-slate-900 dark:text-slate-100 tracking-tight mb-2">
          Ethereum Upgrade Tracker
        </h1>
        <p class="text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
          See what's on the horizon and how it impacts you.
        </p>
      </div>

      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-medium text-slate-900 dark:text-slate-100">Network Upgrades</h2>
          <a
            href="/upgrades"
            class="text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
            >View all upgrades →</a
          >
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {quickLinks.map((upgrade) => <UpgradeCard upgrade={upgrade} />)}
        </div>
      </div>

      <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-medium text-slate-900 dark:text-slate-100">Recently Updated EIPs</h2>
          <a
            href="/eips"
            class="text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
            >Browse all EIPs →</a
          >
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            featuredEips.map((eip) => {
              const mostRecentFork =
                eip.forkRelationships.length > 0
                  ? eip.forkRelationships[eip.forkRelationships.length - 1]
                  : null;
              const inclusionStage = mostRecentFork
                ? getInclusionStage(eip, mostRecentFork.forkName)
                : null;
              return (
                <a
                  href={`/eips/${eip.id}`}
                  class="group flex items-start justify-between gap-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4 hover:shadow-md dark:hover:shadow-slate-700/20 hover:border-purple-300 dark:hover:border-purple-600"
                >
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-2 flex-wrap">
                      <span class="text-sm font-mono font-medium text-purple-600 dark:text-purple-400">
                        {getProposalPrefix(eip)}-{eip.id}
                      </span>
                      {inclusionStage && inclusionStage !== 'Unknown' && (
                        <span class="px-2 py-0.5 text-xs font-medium rounded bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300">
                          {getStageLabel(inclusionStage)}
                        </span>
                      )}
                      {mostRecentFork && (
                        <span class={`px-2 py-0.5 text-xs font-medium rounded ${getForkColor(mostRecentFork.forkName)}`}>
                          {getForkDisplayName(mostRecentFork.forkName)}
                        </span>
                      )}
                    </div>
                    <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100 mb-1 leading-snug">
                      {getLaymanTitle(eip)}
                    </h3>
                    <p class="text-xs text-slate-600 dark:text-slate-400 line-clamp-2">
                      {eip.laymanDescription || eip.description}
                    </p>
                  </div>
                  <svg
                    class="w-5 h-5 text-slate-400 group-hover:text-purple-500 flex-shrink-0 mt-0.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={arrowPath} />
                  </svg>
                </a>
              );
            })
          }
        </div>
      </div>

      <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-medium text-slate-900 dark:text-slate-100">Recent Protocol Calls</h2>
          <a
            href="/calls"
            class="text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
            >View all calls →</a
          >
        </div>

        <div class="space-y-2">
          {
            recentCalls.map((call) => {
              const oneOff = isOneOffCall(call.type);
              return (
                <a
                  href={`/calls/${call.path}`}
                  class="group flex items-center justify-between gap-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4 hover:shadow-md dark:hover:shadow-slate-700/20 hover:border-purple-300 dark:hover:border-purple-600"
                >
                  <div class="flex items-center gap-3 min-w-0">
                    <span class={`inline-block text-xs font-medium px-2 py-0.5 rounded min-w-[3.5rem] text-center flex-shrink-0 ${callTypeBadgeColors[call.type as CallType] || fallbackBadgeColor}`}>
                      {oneOff ? '1-OFF' : call.type.toUpperCase()}
                    </span>
                    <span class="text-sm font-medium text-slate-900 dark:text-slate-100 truncate">
                      {oneOff ? (
                        call.name || call.type
                      ) : (
                        <>
                          <span class="sm:hidden">Call #{call.number}</span>
                          <span class="hidden sm:inline">
                            {callTypeNames[call.type as CallType] || call.type} #{call.number}
                          </span>
                        </>
                      )}
                    </span>
                  </div>
                  <div class="flex items-center gap-3 flex-shrink-0">
                    <span class="text-sm text-slate-600 dark:text-slate-400">{call.date}</span>
                    <svg
                      class="w-5 h-5 text-slate-400 group-hover:text-purple-500 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={arrowPath} />
                    </svg>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>

      {
        recentMeetingDecisions && (
          <div class="mt-12">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-medium text-slate-900 dark:text-slate-100">Recent Decisions</h2>
              <a
                href="/decisions"
                class="text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
              >
                View all decisions →
              </a>
            </div>

            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg overflow-hidden">
              <a
                href={`/calls/${recentMeetingDecisions.call.path}`}
                class="group flex items-center justify-between gap-3 px-4 py-3 border-b border-slate-100 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors"
              >
                <div class="flex items-center gap-3 min-w-0">
                  <span class={`inline-block text-xs font-medium px-2 py-0.5 rounded min-w-[3.5rem] text-center flex-shrink-0 ${callTypeBadgeColors[recentMeetingDecisions.call.type as CallType]}`}>
                    {recentMeetingDecisions.call.type.toUpperCase()}
                  </span>
                  <span class="text-sm font-medium text-slate-900 dark:text-slate-100 truncate">
                    {callTypeNames[recentMeetingDecisions.call.type as CallType]} #{recentMeetingDecisions.call.number}
                  </span>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <span class="hidden sm:inline text-sm text-slate-600 dark:text-slate-400">
                    {recentMeetingDecisions.call.date}
                  </span>
                  <svg class="w-5 h-5 text-slate-400 group-hover:text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={arrowPath} />
                  </svg>
                </div>
              </a>

              <ul class="px-4 py-3 space-y-1.5 list-none">
                {recentMeetingDecisions.decisions.map((decision) => (
                  <li
                    class="text-sm before:content-['→'] before:mr-2 before:text-slate-400 dark:before:text-slate-500 text-slate-600 dark:text-slate-400"
                  ><KeyDecisionText decision={decision} /></li>
                ))}
              </ul>
            </div>
          </div>
        )
      }

      <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-medium text-slate-900 dark:text-slate-100">Planning Tools</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a
            href="/schedule"
            class="group flex items-start gap-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4 hover:shadow-md dark:hover:shadow-slate-700/20 hover:border-purple-300 dark:hover:border-purple-600"
          >
            <div class="flex-shrink-0 w-9 h-9 bg-blue-100 dark:bg-blue-900/40 rounded-lg flex items-center justify-center text-blue-600 dark:text-blue-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100 mb-1">Schedule</h3>
              <p class="text-xs text-slate-600 dark:text-slate-400">
                Plan fork timelines with adjustable milestones
              </p>
            </div>
            <svg class="w-5 h-5 text-slate-400 group-hover:text-purple-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={arrowPath} />
            </svg>
          </a>

          <a
            href="/devnets"
            class="group flex items-start gap-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4 hover:shadow-md dark:hover:shadow-slate-700/20 hover:border-purple-300 dark:hover:border-purple-600"
          >
            <div class="flex-shrink-0 w-9 h-9 bg-emerald-100 dark:bg-emerald-900/40 rounded-lg flex items-center justify-center text-emerald-600 dark:text-emerald-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100 mb-1">Devnets</h3>
              <p class="text-xs text-slate-600 dark:text-slate-400">
                Active devnet series and combined inclusion status
              </p>
            </div>
            <svg class="w-5 h-5 text-slate-400 group-hover:text-purple-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={arrowPath} />
            </svg>
          </a>
        </div>
      </div>

      <div class="mt-16 text-center text-sm text-slate-500 dark:text-slate-400">
        <div class="mb-6">
          <a
            href="https://ps.ethereum.foundation"
            target="_blank"
            rel="noopener noreferrer"
            data-track-link="team_website"
            class="w-16 h-16 mx-auto mb-3 flex items-center justify-center"
          >
            <img
              src="/blobby-gradient-red.svg"
              alt="Ethereum Foundation Protocol Support team logo"
              class="w-16 h-16 hover:invert dark:invert dark:hover:invert-0 transition-all duration-500"
            />
          </a>
          <div class="text-center">
            <p class="text-sm italic text-slate-500 dark:text-slate-400">Brought to you by</p>
            <a
              href="https://ps.ethereum.foundation"
              target="_blank"
              rel="noopener noreferrer"
              data-track-link="team_website"
              class="text-lg font-light text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-slate-100 transition-colors duration-200"
            >
              EF Protocol Support
            </a>
          </div>
        </div>
        <div class="flex items-center justify-center gap-4">
          <a
            href="https://ps.ethereum.foundation"
            target="_blank"
            rel="noopener noreferrer"
            data-track-link="team_website"
            class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors duration-200"
            aria-label="EF Protocol Support website"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.6 9h16.8M3.6 15h16.8" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3a15.3 15.3 0 014 9 15.3 15.3 0 01-4 9 15.3 15.3 0 01-4-9 15.3 15.3 0 014-9z" />
            </svg>
          </a>
          <a
            href="https://github.com/ethereum/forkcast"
            target="_blank"
            rel="noopener noreferrer"
            data-track-link="source_code"
            class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors duration-200"
            aria-label="View source code on GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a
            href="https://x.com/EFProtocol"
            target="_blank"
            rel="noopener noreferrer"
            data-track-link="twitter"
            class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors duration-200"
            aria-label="EF Protocol Support on X"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  {recentMeetingDecisions && <EipPreviewLayer eips={decisionEipPreviews} />}
</Layout>

<script>
  import '../scripts/trackLinks';
</script>
